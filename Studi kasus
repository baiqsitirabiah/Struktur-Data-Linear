#STACK
def balik_kata(kata):
    stack = []
    for balik in kata:
        stack.append(balik)

    hasil = ""
    while stack:
        hasil += stack.pop()
 
    return hasil

kata = "engginering" 
print ("Kata asli:", kata)
print("Kata terbalik:", balik_kata(kata))


from collections import deque
queue = deque()
def enqueue(nama):
    queue.append(nama)
    print(nama,"telah masuk ke dalam antrian")

def dequeue():
    if queue:
        nama = queue.popleft()
        print(nama,"telah dilayani dan keluar dari antrian")
        
    else:
        print("antrian kosong tidak ada yang bisa dilayani")
def tampilkan():
    print("antrian saat ini:",queue)

enqueue("baiqrabiq")
enqueue("tanzila")
enqueue("pia")
tampilkan()
dequeue()
tampilkan()


